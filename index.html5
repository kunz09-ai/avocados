<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ace's Avocados 🥑</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    /* ─── Variables ─────────────────────────────────────────────── */
    :root {
      --avo-dark:   #2d5016;
      --avo-mid:    #4a7c24;
      --avo-bright: #7ab648;
      --avo-light:  #c8e6a0;
      --avo-cream:  #fdf6e3;
      --avo-tan:    #f5e6c8;
      --avo-pit:    #8b5e3c;
      --avo-pit-light: #c4956a;
      --text-dark:  #1e3309;
      --text-mid:   #3d5c1a;
      --white:      #ffffff;
      --shadow:     rgba(45, 80, 22, 0.15);
    }

    /* ─── Reset & Base ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito', sans-serif;
      background-color: var(--avo-cream);
      color: var(--text-dark);
      overflow-x: hidden;
    }

    /* ─── Floating Avocado Background ──────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(ellipse at 10% 20%, rgba(122,182,72,0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 90% 80%, rgba(74,124,36,0.06) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    /* ─── Nav ───────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--avo-dark);
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 3px 12px rgba(0,0,0,0.25);
    }
    .nav-logo {
      font-family: 'Fredoka One', cursive;
      color: var(--avo-light);
      font-size: 1.5rem;
      letter-spacing: 0.5px;
    }
    .nav-logo span { color: var(--avo-bright); }
    nav ul {
      list-style: none;
      display: flex;
      gap: 1.5rem;
    }
    nav a {
      color: var(--avo-light);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.95rem;
      transition: color 0.2s;
    }
    nav a:hover { color: var(--white); }

    /* ─── Hero ──────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 4rem 2rem 5rem;
      overflow: hidden;
    }
    .hero-bg-circle {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, var(--avo-light) 0%, transparent 70%);
      opacity: 0.45;
      pointer-events: none;
    }
    .hero-bg-circle.c1 { width: 600px; height: 600px; top: -180px; left: -140px; }
    .hero-bg-circle.c2 { width: 400px; height: 400px; bottom: -100px; right: -100px; }

    .avo-illustration {
      width: 180px;
      height: 220px;
      margin-bottom: 1.5rem;
      animation: float 3.5s ease-in-out infinite;
      filter: drop-shadow(0 12px 24px rgba(45,80,22,0.25));
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(-2deg); }
      50%       { transform: translateY(-14px) rotate(2deg); }
    }

    .hero h1 {
      font-family: 'Fredoka One', cursive;
      font-size: clamp(3rem, 8vw, 6rem);
      color: var(--avo-dark);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .hero h1 .highlight {
      color: var(--avo-mid);
      display: block;
    }
    .hero-sub {
      font-size: clamp(1.05rem, 2.5vw, 1.35rem);
      color: var(--text-mid);
      max-width: 540px;
      margin: 1rem auto 2rem;
      font-weight: 600;
      font-style: italic;
    }
    .badge-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .badge {
      background: var(--avo-bright);
      color: var(--white);
      font-weight: 700;
      font-size: 0.85rem;
      padding: 0.35rem 0.9rem;
      border-radius: 99px;
      letter-spacing: 0.3px;
    }
    .badge.dark { background: var(--avo-dark); }
    .badge.pit  { background: var(--avo-pit); }

    .cta-btn {
      display: inline-block;
      background: var(--avo-mid);
      color: var(--white);
      font-family: 'Fredoka One', cursive;
      font-size: 1.25rem;
      padding: 0.85rem 2.5rem;
      border-radius: 99px;
      text-decoration: none;
      box-shadow: 0 6px 20px rgba(74,124,36,0.4);
      transition: transform 0.2s, box-shadow 0.2s;
      letter-spacing: 0.5px;
    }
    .cta-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(74,124,36,0.45);
    }

    /* ─── Wavy Divider ──────────────────────────────────────────── */
    .wave-divider { display: block; width: 100%; line-height: 0; }
    .wave-divider svg { display: block; }

    /* ─── Sections ──────────────────────────────────────────────── */
    section { position: relative; z-index: 1; }
    .section-inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .section-title {
      font-family: 'Fredoka One', cursive;
      font-size: clamp(2rem, 5vw, 3rem);
      color: var(--avo-dark);
      margin-bottom: 0.5rem;
    }
    .section-sub {
      color: var(--text-mid);
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
      font-weight: 600;
    }

    /* ─── About Strip ───────────────────────────────────────────── */
    .about-strip {
      background: var(--avo-dark);
      color: var(--avo-cream);
    }
    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }
    .about-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(200,230,160,0.15);
      border-radius: 1.25rem;
      padding: 1.5rem;
      text-align: center;
    }
    .about-card .icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .about-card h3 { font-family: 'Fredoka One', cursive; font-size: 1.2rem; color: var(--avo-light); margin-bottom: 0.4rem; }
    .about-card p  { font-size: 0.92rem; color: rgba(253,246,227,0.8); line-height: 1.5; }

    /* ─── Sign-Up Section ───────────────────────────────────────── */
    .signup-section { background: var(--avo-tan); }
    .signup-form-wrap {
      background: var(--white);
      border-radius: 1.5rem;
      padding: 2.5rem;
      box-shadow: 0 8px 32px var(--shadow);
    }
    .form-row { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
    .form-row label { font-weight: 700; font-size: 0.9rem; color: var(--avo-dark); }
    .form-row input, .form-row select, .form-row textarea {
      border: 2px solid var(--avo-light);
      border-radius: 0.75rem;
      padding: 0.65rem 1rem;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      color: var(--text-dark);
      background: var(--avo-cream);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    .form-row input:focus, .form-row select:focus, .form-row textarea:focus {
      border-color: var(--avo-mid);
      box-shadow: 0 0 0 3px rgba(74,124,36,0.12);
    }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 1.25rem; }
    @media (max-width: 560px) { .form-grid { grid-template-columns: 1fr; } }
    .submit-btn {
      width: 100%;
      background: var(--avo-mid);
      color: var(--white);
      border: none;
      border-radius: 99px;
      font-family: 'Fredoka One', cursive;
      font-size: 1.2rem;
      padding: 0.85rem;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      margin-top: 0.5rem;
      letter-spacing: 0.5px;
    }
    .submit-btn:hover { background: var(--avo-dark); transform: translateY(-2px); }
    .form-notice {
      text-align: center;
      font-size: 0.82rem;
      color: var(--text-mid);
      margin-top: 1rem;
    }
    .success-msg {
      display: none;
      text-align: center;
      padding: 2rem;
      font-family: 'Fredoka One', cursive;
      font-size: 1.5rem;
      color: var(--avo-dark);
    }

    /* ─── Deliveries Section ────────────────────────────────────── */
    .deliveries-section { background: var(--avo-cream); }
    .delivery-table-wrap {
      overflow-x: auto;
      border-radius: 1rem;
      box-shadow: 0 4px 20px var(--shadow);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--white);
      border-radius: 1rem;
      overflow: hidden;
    }
    thead { background: var(--avo-mid); color: var(--white); }
    th { padding: 0.9rem 1.2rem; text-align: left; font-family: 'Fredoka One', cursive; font-size: 1rem; letter-spacing: 0.3px; }
    td { padding: 0.85rem 1.2rem; border-bottom: 1px solid var(--avo-light); font-size: 0.95rem; }
    tr:last-child td { border-bottom: none; }
    tr:nth-child(even) td { background: rgba(200,230,160,0.12); }
    .status-pill {
      display: inline-block;
      padding: 0.2rem 0.7rem;
      border-radius: 99px;
      font-size: 0.78rem;
      font-weight: 700;
    }
    .status-pill.ready   { background: #d4edda; color: #155724; }
    .status-pill.coming  { background: #fff3cd; color: #856404; }
    .status-pill.sold    { background: #f8d7da; color: #721c24; }
    .delivery-empty {
      text-align: center;
      padding: 2.5rem;
      color: var(--text-mid);
      font-style: italic;
    }

    /* ─── Venmo Section ─────────────────────────────────────────── */
    .venmo-section { background: var(--avo-tan); }
    .venmo-card {
      background: var(--white);
      border-radius: 1.5rem;
      padding: 2.5rem;
      box-shadow: 0 8px 32px var(--shadow);
      display: flex;
      align-items: center;
      gap: 2.5rem;
      flex-wrap: wrap;
    }
    .venmo-qr-area {
      flex: 0 0 auto;
      text-align: center;
    }
    .qr-placeholder {
      width: 180px;
      height: 180px;
      border: 3px dashed var(--avo-light);
      border-radius: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 0.5rem;
      color: var(--text-mid);
      font-size: 0.85rem;
      font-weight: 700;
      background: var(--avo-cream);
      cursor: pointer;
      transition: border-color 0.2s;
      overflow: hidden;
      position: relative;
    }
    .qr-placeholder:hover { border-color: var(--avo-mid); }
    .qr-placeholder img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 0.75rem;
    }
    .qr-upload-label {
      display: block;
      cursor: pointer;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
    }
    #qr-file-input { display: none; }
    .venmo-info { flex: 1; min-width: 220px; }
    .venmo-info h3 {
      font-family: 'Fredoka One', cursive;
      font-size: 1.5rem;
      color: var(--avo-dark);
      margin-bottom: 0.5rem;
    }
    .venmo-info p { color: var(--text-mid); line-height: 1.6; margin-bottom: 1rem; }
    .venmo-handle {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #3d95ce;
      color: var(--white);
      border-radius: 99px;
      padding: 0.4rem 1rem;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
    }

    /* ─── Admin Panel ───────────────────────────────────────────── */
    .admin-section { background: var(--avo-dark); }
    .admin-section .section-title { color: var(--avo-light); }
    .admin-section .section-sub   { color: rgba(253,246,227,0.7); }
    .admin-login-card, .admin-panel-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(200,230,160,0.2);
      border-radius: 1.5rem;
      padding: 2rem;
      max-width: 500px;
      margin: 0 auto;
    }
    .admin-login-card .form-row input { background: rgba(255,255,255,0.08); border-color: rgba(200,230,160,0.3); color: var(--avo-cream); }
    .admin-panel-card { max-width: 860px; }
    .admin-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .tab-btn {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(200,230,160,0.2);
      border-radius: 99px;
      color: var(--avo-light);
      font-family: 'Fredoka One', cursive;
      font-size: 1rem;
      padding: 0.4rem 1.2rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .tab-btn.active { background: var(--avo-bright); color: var(--white); border-color: transparent; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }
    .admin-form-label { color: var(--avo-light); font-weight: 700; font-size: 0.88rem; margin-bottom: 0.3rem; display: block; }
    .admin-input {
      width: 100%;
      background: rgba(255,255,255,0.08);
      border: 1.5px solid rgba(200,230,160,0.25);
      border-radius: 0.75rem;
      padding: 0.6rem 1rem;
      color: var(--avo-cream);
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      margin-bottom: 1rem;
      outline: none;
    }
    .admin-input:focus { border-color: var(--avo-bright); }
    .admin-btn {
      background: var(--avo-bright);
      color: var(--white);
      border: none;
      border-radius: 99px;
      font-family: 'Fredoka One', cursive;
      font-size: 1.05rem;
      padding: 0.65rem 1.75rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .admin-btn:hover { background: var(--avo-mid); }
    .admin-btn.danger { background: #c0392b; }
    .admin-btn.danger:hover { background: #922b21; }
    .customer-list-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    .customer-list-table th { background: rgba(255,255,255,0.1); color: var(--avo-light); padding: 0.6rem 0.9rem; text-align: left; font-size: 0.88rem; }
    .customer-list-table td { padding: 0.6rem 0.9rem; border-bottom: 1px solid rgba(200,230,160,0.1); color: var(--avo-cream); font-size: 0.88rem; }
    .qty-input { width: 60px; background: rgba(255,255,255,0.1); border: 1px solid rgba(200,230,160,0.25); border-radius: 0.4rem; color: var(--avo-cream); padding: 0.25rem 0.4rem; font-size: 0.88rem; text-align: center; }
    .admin-summary {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .admin-stat {
      flex: 1;
      min-width: 140px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(200,230,160,0.15);
      border-radius: 1rem;
      padding: 1rem 1.25rem;
      text-align: center;
    }
    .admin-stat .num { font-family: 'Fredoka One', cursive; font-size: 2rem; color: var(--avo-bright); }
    .admin-stat .lbl { font-size: 0.78rem; color: rgba(253,246,227,0.6); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .notify-banner {
      background: rgba(122,182,72,0.15);
      border: 1px solid rgba(122,182,72,0.3);
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      color: var(--avo-light);
      font-size: 0.9rem;
      margin-top: 1rem;
      display: none;
    }

    /* ─── Footer ────────────────────────────────────────────────── */
    footer {
      background: var(--avo-dark);
      color: rgba(253,246,227,0.5);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.82rem;
    }
    footer strong { color: var(--avo-light); }

    /* ─── Scroll animations ─────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">🥑 <span>Ace's</span> Avocados</div>
  <ul>
    <li><a href="#about">About</a></li>
    <li><a href="#signup">Sign Up</a></li>
    <li><a href="#deliveries">Deliveries</a></li>
    <li><a href="#pay">Pay</a></li>
    <li><a href="#admin">Ace's Login</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg-circle c1"></div>
  <div class="hero-bg-circle c2"></div>

  <!-- Inline SVG avocado illustration -->
  <svg class="avo-illustration" viewBox="0 0 180 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Avocado illustration">
    <ellipse cx="90" cy="118" rx="72" ry="90" fill="#4a7c24"/>
    <ellipse cx="90" cy="105" rx="60" ry="75" fill="#7ab648"/>
    <ellipse cx="90" cy="95" rx="48" ry="62" fill="#c8e6a0"/>
    <ellipse cx="90" cy="120" rx="28" ry="34" fill="#8b5e3c"/>
    <ellipse cx="90" cy="118" rx="22" ry="28" fill="#c4956a"/>
    <!-- leaf -->
    <ellipse cx="90" cy="30" rx="18" ry="34" fill="#4a7c24" transform="rotate(-15 90 30)"/>
    <ellipse cx="90" cy="30" rx="18" ry="34" fill="#7ab648" transform="rotate(15 90 30)"/>
    <line x1="90" y1="12" x2="90" y2="58" stroke="#2d5016" stroke-width="2.5" stroke-linecap="round"/>
    <!-- shine -->
    <ellipse cx="70" cy="80" rx="8" ry="14" fill="white" opacity="0.2" transform="rotate(-20 70 80)"/>
  </svg>

  <h1>Ace's <span class="highlight">Avocados</span></h1>
  <p class="hero-sub">Fresh from our backyard tree 🌳 straight to your lunchbox — the best avocados at school, delivered with love!</p>

  <div class="badge-row">
    <span class="badge">🏡 Home Grown</span>
    <span class="badge dark">🥑 Super Fresh</span>
    <span class="badge pit">💚 Kid-Run Business</span>
  </div>

  <a class="cta-btn" href="#signup">Get on the List!</a>
</section>

<!-- WAVE DOWN -->
<div class="wave-divider">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" height="80">
    <path d="M0,40 C360,90 1080,-10 1440,40 L1440,80 L0,80 Z" fill="#2d5016"/>
  </svg>
</div>

<!-- ABOUT -->
<section id="about" class="about-strip">
  <div class="section-inner reveal">
    <div class="section-title" style="color:var(--avo-light)">Why Ace's Avocados?</div>
    <div class="section-sub" style="color:rgba(253,246,227,0.7)">Our tree makes WAY more than we can eat — so we're sharing the love!</div>
    <div class="about-grid">
      <div class="about-card">
        <div class="icon">🥑</div>
        <h3>Truly Fresh</h3>
        <p>Picked right from our backyard tree. No store, no trucking — just real, ripe avocados.</p>
      </div>
      <div class="about-card">
        <div class="icon">👦</div>
        <h3>Kid-Run</h3>
        <p>Ace handles orders with his family's help. Supporting him means supporting a young entrepreneur!</p>
      </div>
      <div class="about-card">
        <div class="icon">📬</div>
        <h3>Easy Pick-Up</h3>
        <p>We'll email you when your avocados are ready. Grab them at school — simple as that.</p>
      </div>
      <div class="about-card">
        <div class="icon">💸</div>
        <h3>Fair Prices</h3>
        <p>Cheaper than the grocery store and way tastier. Pay via Venmo — quick and easy.</p>
      </div>
    </div>
  </div>
</section>

<!-- WAVE UP -->
<div class="wave-divider" style="background:#2d5016">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" height="80">
    <path d="M0,40 C360,-10 1080,90 1440,40 L1440,0 L0,0 Z" fill="#2d5016"/>
    <path d="M0,40 C360,-10 1080,90 1440,40 L1440,80 L0,80 Z" fill="#f5e6c8"/>
  </svg>
</div>

<!-- SIGN UP -->
<section id="signup" class="signup-section">
  <div class="section-inner reveal">
    <div class="section-title">Join the Avo Club 🎉</div>
    <div class="section-sub">Sign up to get notified when Ace has avocados ready for you!</div>
    <div class="signup-form-wrap">
      <div id="signup-form-container">
        <div class="form-grid">
          <div class="form-row">
            <label for="first-name">First Name</label>
            <input type="text" id="first-name" placeholder="Your first name" required />
          </div>
          <div class="form-row">
            <label for="last-name">Last Name</label>
            <input type="text" id="last-name" placeholder="Your last name" required />
          </div>
        </div>
        <div class="form-row">
          <label for="email">Email Address</label>
          <input type="email" id="email" placeholder="you@email.com" required />
        </div>
        <div class="form-row">
          <label for="child-name">Your Child's Name (at school)</label>
          <input type="text" id="child-name" placeholder="So we know who to find!" />
        </div>
        <div class="form-row">
          <label for="weekly-qty">How many avocados per week? (when available)</label>
          <select id="weekly-qty">
            <option value="1">1 avocado</option>
            <option value="2" selected>2 avocados</option>
            <option value="3">3 avocados</option>
            <option value="4">4 avocados</option>
            <option value="5">5+ avocados</option>
          </select>
        </div>
        <div class="form-row">
          <label for="notes">Anything else? (optional)</label>
          <textarea id="notes" rows="2" placeholder="e.g. allergies, special requests..."></textarea>
        </div>
        <button class="submit-btn" id="signup-btn" onclick="submitSignup()">🥑 Sign Me Up!</button>
        <p class="form-notice">We'll only email you about avocado deliveries. No spam, promise! 🤝</p>
      </div>
      <div class="success-msg" id="signup-success">
        <div style="font-size:3rem;margin-bottom:0.5rem">🥑</div>
        You're on the list! We'll email you when avocados are ready. Stay fresh!
      </div>
    </div>
  </div>
</section>

<!-- DELIVERIES -->
<section id="deliveries" class="deliveries-section">
  <div class="section-inner reveal">
    <div class="section-title">Delivery Schedule 📅</div>
    <div class="section-sub">Check below to see when the next batch is coming!</div>
    <div class="delivery-table-wrap">
      <table id="delivery-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Avocados Available</th>
            <th>Status</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody id="delivery-tbody">
          <tr>
            <td colspan="4" class="delivery-empty">Loading delivery schedule… 🥑</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- PAY / VENMO -->
<section id="pay" class="venmo-section">
  <div class="section-inner reveal">
    <div class="section-title">Pay Ace 💚</div>
    <div class="section-sub">Scan the QR code below or search Venmo for Ace's handle.</div>
    <div class="venmo-card">
      <div class="venmo-qr-area">
        <div class="qr-placeholder" id="qr-box">
          <label class="qr-upload-label" for="qr-file-input" id="qr-label">
            <span style="font-size:2.5rem">📷</span>
            <span>Click to add<br>Venmo QR Code</span>
          </label>
          <input type="file" id="qr-file-input" accept="image/*" onchange="loadQR(event)" />
        </div>
        <p style="margin-top:0.5rem;font-size:0.78rem;color:var(--text-mid)">Tap to upload your Venmo QR screenshot</p>
      </div>
      <div class="venmo-info">
        <h3>Quick & Easy Payment</h3>
        <p>After picking up your avocados, send payment via Venmo. Update the handle below to match Ace's Venmo username.</p>
        <p><strong>Price:</strong> Ask Ace at pick-up — it changes depending on the week's harvest!</p>
        <a class="venmo-handle" href="https://venmo.com/" target="_blank" id="venmo-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" rx="4" fill="white"/><text x="2" y="13" font-size="11" fill="#3d95ce" font-family="Arial" font-weight="bold">V</text></svg>
          @AcesAvocados
        </a>
        <p style="margin-top:0.75rem;font-size:0.82rem;color:var(--text-mid)">Update handle in the admin panel after connecting Google Sheets.</p>
      </div>
    </div>
  </div>
</section>

<!-- WAVE to admin -->
<div class="wave-divider" style="background:var(--avo-tan)">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" height="80">
    <path d="M0,20 C480,80 960,0 1440,60 L1440,80 L0,80 Z" fill="#2d5016"/>
  </svg>
</div>

<!-- ADMIN -->
<section id="admin" class="admin-section">
  <div class="section-inner">
    <div class="section-title">🔐 Ace's Control Panel</div>
    <div class="section-sub">Family login — manage inventory, assign avocados, and send notifications.</div>

    <!-- Login -->
    <div class="admin-login-card" id="admin-login">
      <div class="form-row">
        <label class="admin-form-label" for="admin-pass">Password</label>
        <input type="password" id="admin-pass" class="admin-input" placeholder="Enter family password" />
      </div>
      <button class="admin-btn" onclick="adminLogin()">Log In</button>
      <p style="color:rgba(253,246,227,0.4);font-size:0.78rem;margin-top:0.75rem;">
        Set the password in your Google Apps Script config.
      </p>
    </div>

    <!-- Panel -->
    <div class="admin-panel-card" id="admin-panel" style="display:none">
      <div class="admin-summary">
        <div class="admin-stat"><div class="num" id="stat-customers">–</div><div class="lbl">Customers</div></div>
        <div class="admin-stat"><div class="num" id="stat-avail">–</div><div class="lbl">Available This Week</div></div>
        <div class="admin-stat"><div class="num" id="stat-assigned">–</div><div class="lbl">Assigned</div></div>
        <div class="admin-stat"><div class="num" id="stat-remaining">–</div><div class="lbl">Remaining</div></div>
      </div>

      <div class="admin-tabs">
        <button class="tab-btn active" onclick="switchTab('inventory')">🥑 Inventory</button>
        <button class="tab-btn" onclick="switchTab('assign')">📋 Assign</button>
        <button class="tab-btn" onclick="switchTab('notify')">📧 Notify</button>
        <button class="tab-btn" onclick="switchTab('customers')">👥 Customers</button>
        <button class="tab-btn" onclick="switchTab('settings')">⚙️ Settings</button>
      </div>

      <!-- Inventory Tab -->
      <div class="tab-pane active" id="tab-inventory">
        <label class="admin-form-label">This week's delivery date</label>
        <input type="date" id="delivery-date" class="admin-input" />
        <label class="admin-form-label">Total avocados available this week</label>
        <input type="number" id="total-avos" class="admin-input" min="0" placeholder="e.g. 24" />
        <label class="admin-form-label">Price per avocado ($)</label>
        <input type="number" id="price-per" class="admin-input" min="0" step="0.25" placeholder="e.g. 1.00" />
        <label class="admin-form-label">Notes for customers (optional)</label>
        <input type="text" id="delivery-notes" class="admin-input" placeholder="e.g. Extra ripe this week!" />
        <button class="admin-btn" onclick="saveInventory()">💾 Save Inventory</button>
      </div>

      <!-- Assign Tab -->
      <div class="tab-pane" id="tab-assign">
        <p style="color:rgba(253,246,227,0.7);font-size:0.88rem;margin-bottom:1rem;">Set how many avocados each customer gets this week.</p>
        <div style="overflow-x:auto">
          <table class="customer-list-table" id="assign-table">
            <thead><tr><th>Name</th><th>Email</th><th>Wants</th><th>Assign Qty</th></tr></thead>
            <tbody id="assign-tbody"><tr><td colspan="4" style="color:rgba(253,246,227,0.4);font-style:italic;padding:1rem">Load customers from Google Sheets…</td></tr></tbody>
          </table>
        </div>
        <br/>
        <button class="admin-btn" onclick="saveAssignments()">💾 Save Assignments</button>
      </div>

      <!-- Notify Tab -->
      <div class="tab-pane" id="tab-notify">
        <p style="color:rgba(253,246,227,0.7);font-size:0.88rem;margin-bottom:1.25rem;">Send email notifications to all customers who have avocados assigned this week.</p>
        <label class="admin-form-label">Custom message (optional — added to the email)</label>
        <textarea id="custom-msg" class="admin-input" rows="3" placeholder="e.g. These ones are extra buttery — enjoy!"></textarea>
        <button class="admin-btn" onclick="sendNotifications()">📧 Send Notifications</button>
        <div class="notify-banner" id="notify-banner">✅ Notifications sent! Customers will receive their emails shortly.</div>
      </div>

      <!-- Customers Tab -->
      <div class="tab-pane" id="tab-customers">
        <div style="overflow-x:auto">
          <table class="customer-list-table" id="customers-table">
            <thead><tr><th>Name</th><th>Email</th><th>Child</th><th>Wants/wk</th><th>Notes</th><th>Remove</th></tr></thead>
            <tbody id="customers-tbody"><tr><td colspan="6" style="color:rgba(253,246,227,0.4);font-style:italic;padding:1rem">Loading…</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- Settings Tab -->
      <div class="tab-pane" id="tab-settings">
        <label class="admin-form-label">Venmo Handle (without @)</label>
        <input type="text" id="venmo-handle" class="admin-input" placeholder="AcesAvocados" />
        <label class="admin-form-label">Admin Password (change)</label>
        <input type="password" id="new-password" class="admin-input" placeholder="New password" />
        <button class="admin-btn" onclick="saveSettings()">💾 Save Settings</button>
        <br/><br/>
        <button class="admin-btn danger" onclick="adminLogout()">🚪 Log Out</button>
      </div>

      <div class="notify-banner" id="admin-msg" style="margin-top:1rem"></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p>Made with 💚 by <strong>Ace's Avocados</strong> · Home-grown, school-delivered · <a href="#signup" style="color:var(--avo-light)">Join the list</a></p>
</footer>

<!-- ─── SCRIPTS ──────────────────────────────────────────────────────── -->
<script>
  // ═══════════════════════════════════════════════════════════
  //  CONFIGURATION — replace with your deployed Apps Script URL
  // ═══════════════════════════════════════════════════════════
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwgOrxEu5wmrxz81mbtyw9qLodloV5e1vjck2a2oakThl8zDfWw2UtLMIe0MwIBDWIV/exec';

  // ─── Scroll reveal ─────────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ─── QR Code upload ────────────────────────────────────────
  function loadQR(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      const box = document.getElementById('qr-box');
      box.innerHTML = `<img src="${ev.target.result}" alt="Venmo QR Code" />`;
      localStorage.setItem('venmo_qr', ev.target.result);
    };
    reader.readAsDataURL(file);
  }
  // restore saved QR
  window.addEventListener('load', () => {
    const saved = localStorage.getItem('venmo_qr');
    if (saved) {
      document.getElementById('qr-box').innerHTML = `<img src="${saved}" alt="Venmo QR Code" />`;
    }
  });

  // ─── Customer Sign-Up ───────────────────────────────────────
  async function submitSignup() {
    const btn = document.getElementById('signup-btn');
    const firstName = document.getElementById('first-name').value.trim();
    const lastName  = document.getElementById('last-name').value.trim();
    const email     = document.getElementById('email').value.trim();
    const child     = document.getElementById('child-name').value.trim();
    const qty       = document.getElementById('weekly-qty').value;
    const notes     = document.getElementById('notes').value.trim();

    if (!firstName || !lastName || !email) { alert('Please fill in your name and email!'); return; }

    btn.textContent = '🥑 Signing you up…';
    btn.disabled = true;

    try {
      const params = new URLSearchParams({ action:'signup', firstName, lastName, email, child, qty, notes });
      await fetch(SCRIPT_URL + '?' + params);
      document.getElementById('signup-form-container').style.display = 'none';
      document.getElementById('signup-success').style.display = 'block';
    } catch {
      btn.textContent = '🥑 Sign Me Up!';
      btn.disabled = false;
      alert('Hmm, something went wrong. Try again!');
    }
  }

  // ─── Load Delivery Schedule ─────────────────────────────────
  async function loadDeliveries() {
    try {
      const res  = await fetch(SCRIPT_URL + '?action=getDeliveries');
      const data = await res.json();
      const tbody = document.getElementById('delivery-tbody');
      if (!data || !data.length) {
        tbody.innerHTML = `<tr><td colspan="4" class="delivery-empty">No deliveries scheduled yet — check back soon! 🥑</td></tr>`;
        return;
      }
      tbody.innerHTML = data.map(d => `
        <tr>
          <td>${d.date}</td>
          <td>${d.total}</td>
          <td><span class="status-pill ${d.statusClass}">${d.status}</span></td>
          <td>${d.notes || '—'}</td>
        </tr>`).join('');
    } catch {
      document.getElementById('delivery-tbody').innerHTML =
        `<tr><td colspan="4" class="delivery-empty">Could not load schedule. Connect your Google Sheet to see deliveries.</td></tr>`;
    }
  }
  loadDeliveries();

  // ─── Admin Auth ─────────────────────────────────────────────
  async function adminLogin() {
    const pass = document.getElementById('admin-pass').value;
    try {
      const res  = await fetch(SCRIPT_URL + `?action=adminLogin&password=${encodeURIComponent(pass)}`);
      const data = await res.json();
      if (data.success) {
        sessionStorage.setItem('admin_token', data.token);
        document.getElementById('admin-login').style.display = 'none';
        document.getElementById('admin-panel').style.display = 'block';
        loadAdminData();
      } else {
        alert('Wrong password! Try again.');
      }
    } catch {
      alert('Could not connect. Check your Apps Script URL.');
    }
  }

  function adminLogout() {
    sessionStorage.removeItem('admin_token');
    document.getElementById('admin-login').style.display = 'block';
    document.getElementById('admin-panel').style.display = 'none';
  }

  function authHeaders() {
    return `&token=${sessionStorage.getItem('admin_token')}`;
  }

  // ─── Load Admin Data ────────────────────────────────────────
  async function loadAdminData() {
    try {
      const res  = await fetch(SCRIPT_URL + '?action=getAdminData' + authHeaders());
      const d    = await res.json();

      document.getElementById('stat-customers').textContent  = d.totalCustomers || 0;
      document.getElementById('stat-avail').textContent      = d.availableThisWeek || 0;
      document.getElementById('stat-assigned').textContent   = d.assignedThisWeek || 0;
      document.getElementById('stat-remaining').textContent  = d.remaining || 0;

      if (d.deliveryDate) document.getElementById('delivery-date').value = d.deliveryDate;
      if (d.totalAvos)   document.getElementById('total-avos').value   = d.totalAvos;
      if (d.price)       document.getElementById('price-per').value    = d.price;
      if (d.notes)       document.getElementById('delivery-notes').value = d.notes;

      renderAssignTable(d.customers || []);
      renderCustomersTable(d.customers || []);
    } catch (e) {
      console.error(e);
    }
  }

  function renderAssignTable(customers) {
    const tbody = document.getElementById('assign-tbody');
    if (!customers.length) { tbody.innerHTML = '<tr><td colspan="4" style="color:rgba(253,246,227,0.4);padding:1rem">No customers yet.</td></tr>'; return; }
    tbody.innerHTML = customers.map((c, i) => `
      <tr>
        <td>${c.firstName} ${c.lastName}</td>
        <td>${c.email}</td>
        <td>${c.qty}</td>
        <td><input class="qty-input" type="number" min="0" value="${c.assignedQty || 0}" id="assign-${i}" data-email="${c.email}" /></td>
      </tr>`).join('');
  }

  function renderCustomersTable(customers) {
    const tbody = document.getElementById('customers-tbody');
    if (!customers.length) { tbody.innerHTML = '<tr><td colspan="6" style="color:rgba(253,246,227,0.4);padding:1rem">No customers yet.</td></tr>'; return; }
    tbody.innerHTML = customers.map(c => `
      <tr>
        <td>${c.firstName} ${c.lastName}</td>
        <td>${c.email}</td>
        <td>${c.child || '—'}</td>
        <td>${c.qty}</td>
        <td>${c.notes || '—'}</td>
        <td><button class="admin-btn danger" style="padding:0.25rem 0.6rem;font-size:0.8rem" onclick="removeCustomer('${c.email}')">✕</button></td>
      </tr>`).join('');
  }

  // ─── Admin Actions ──────────────────────────────────────────
  async function saveInventory() {
    const body = {
      action: 'saveInventory',
      token: sessionStorage.getItem('admin_token'),
      deliveryDate: document.getElementById('delivery-date').value,
      totalAvos:    document.getElementById('total-avos').value,
      price:        document.getElementById('price-per').value,
      notes:        document.getElementById('delivery-notes').value
    };
    await postAdmin(body);
    showAdminMsg('✅ Inventory saved!');
    loadAdminData();
    loadDeliveries();
  }

  async function saveAssignments() {
    const inputs = document.querySelectorAll('#assign-tbody .qty-input');
    const assignments = Array.from(inputs).map(i => ({ email: i.dataset.email, qty: i.value }));
    await postAdmin({ action: 'saveAssignments', token: sessionStorage.getItem('admin_token'), assignments });
    showAdminMsg('✅ Assignments saved!');
    loadAdminData();
  }

  async function sendNotifications() {
    const customMsg = document.getElementById('custom-msg').value;
    await postAdmin({ action: 'sendNotifications', token: sessionStorage.getItem('admin_token'), customMsg });
    document.getElementById('notify-banner').style.display = 'block';
    setTimeout(() => { document.getElementById('notify-banner').style.display = 'none'; }, 4000);
  }

  async function removeCustomer(email) {
    if (!confirm(`Remove ${email} from the list?`)) return;
    await postAdmin({ action: 'removeCustomer', token: sessionStorage.getItem('admin_token'), email });
    showAdminMsg('✅ Customer removed.');
    loadAdminData();
  }

  async function saveSettings() {
    const venmoHandle = document.getElementById('venmo-handle').value.trim();
    const newPassword = document.getElementById('new-password').value;
    await postAdmin({ action: 'saveSettings', token: sessionStorage.getItem('admin_token'), venmoHandle, newPassword });
    if (venmoHandle) {
      document.getElementById('venmo-link').innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect width="16" height="16" rx="4" fill="white"/><text x="2" y="13" font-size="11" fill="#3d95ce" font-family="Arial" font-weight="bold">V</text></svg> @${venmoHandle}`;
      document.getElementById('venmo-link').href = `https://venmo.com/${venmoHandle}`;
    }
    showAdminMsg('✅ Settings saved!');
  }

  async function postAdmin(body) {
    return fetch(SCRIPT_URL, {
      method: 'POST',
      body: JSON.stringify(body),
      headers: { 'Content-Type': 'application/json' }
    }).catch(e => console.error(e));
  }

  function showAdminMsg(msg) {
    const el = document.getElementById('admin-msg');
    el.textContent = msg;
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 3500);
  }

  // ─── Tabs ───────────────────────────────────────────────────
  function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById('tab-' + name).classList.add('active');
  }

  // ─── Restore admin session if already logged in ─────────────
  if (sessionStorage.getItem('admin_token')) {
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-panel').style.display = 'block';
    loadAdminData();
  }
</script>
</body>
</html>
